<?xml version="1.0" encoding="UTF-8"?>
<Window shadow_type="menu_round" shadow_attached="true" layered_window="true"
		xmlns:xs="http://www.w3.org/2001/XMLSchema"
		xmlns="http://tempuri.org/NIMDUISchema.xsd"
		>
	
	<Class name="helperMenuElement" height="24" padding="20,0,20,0" margin="1,1,1,1"
		   hot_color="#CSPColor_Selected"  fade_hot="false"/>
	
	<Class name="helperMenuText" normal_text_color="#CSPColor_Content" font="system_12" valign="center"/>
	
	
	<MenuListBox class="menu" bkcolor="#CSPColor_PanelBG">
		<MenuItem class="helperMenuElement" name="colWheelMenu_Rectangle" width="auto">
			<Label class="helperMenuText"  text_id="STRID_COLORWHEEL_MENU_RECTANGLE" disabled_text_color="#CSPColor_Separator"  mouse_enabled="false" keyboard_enabled="false"/>
		</MenuItem>
		<MenuItem class="helperMenuElement" name="colWheelMenu_Triangle" width="auto">
			<Label class="helperMenuText"  text_id="STRID_COLORWHEEL_MENU_TRIANGLE" mouse_enabled="false" keyboard_enabled="false"/>
		</MenuItem>
		<Control height="1" margin="10,0,10,0" bkcolor="#CSPColor_Separator"/>
		<MenuItem class="helperMenuElement" name="colWheelMenu_Pan" width="auto">
			<Label class="helperMenuText"  text_id="STRID_COLORWHEEL_MENU_PAN" mouse_enabled="false" keyboard_enabled="false"/>
		</MenuItem>
		<MenuItem class="helperMenuElement" name="colWheelMenu_ColorSlider" width="auto">
			<Label class="helperMenuText"  text_id="STRID_COLORWHEEL_MENU_COLORSLIDER" mouse_enabled="false" keyboard_enabled="false"/>
		</MenuItem>
	</MenuListBox>
</Window>